# SiliconFlow local environment for Phase 1 verification
# Fill in the API key below before running real model tests.
# Do not share this file with students after filling the key.

SILICONFLOW_API_KEY=sk-scvsmxqpjbrjaxgmudgemcvlmyidhjajbwmsioywjrlqsnlr
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Default text/chat model for Day2-Day4.
MODEL_TEXT=Pro/moonshotai/Kimi-K2.6

# Day1 model arena models. For the first real run, all three point to the same model.
# Active three-model comparison: Kimi, DeepSeek, Qwen.
MODEL_A=Pro/moonshotai/Kimi-K2.6
MODEL_B=deepseek-ai/DeepSeek-V4-Flash
MODEL_C=Qwen/Qwen3.6-27B

# Optional placeholders for later multimodal/RAG extensions.
# Leave these unchanged unless you have selected models for the class.
MODEL_VISION=Pro/moonshotai/Kimi-K2.6
MODEL_EMBEDDING=REPLACE_WITH_EMBEDDING_MODEL_IF_NEEDED

# Real run flag. Keep MOCK_LLM=0 for real SiliconFlow calls.
# Set MOCK_LLM=1 only when you want to run the offline simulation.
MOCK_LLM=0

# Day4 local cloud service settings.
POCKET_AGENT_HOST=0.0.0.0
POCKET_AGENT_PORT=8000
POCKET_AGENT_MODEL=pocket-campus-agent
POCKET_AGENT_BASE_URL=http://192.168.10.203:8000/v1
